    import os

    ext = os.path.splitext(file_path)[1].lower()
    if ext == ".csv":
        df = pd.read_csv(file_path)
    elif ext in [".xlsx", ".xls"]:
        df = pd.read_excel(file_path, engine="openpyxl")
    elif ext == ".parquet":
        df = pd.read_parquet(file_path, engine="pyarrow")
